# NestJS backend origin. Leave the mock backend running (API_MOCKING=enabled)
# until a real backend is deployed, then point this at it and flip the flag off.
NESTJS_API_URL=http://localhost:3001/api

# When "enabled", app/api/** Route Handlers are served by the MSW mocks in
# src/mocks instead of NESTJS_API_URL. See instrumentation.ts.
API_MOCKING=enabled

# Set false while using the current real Nest backend: notification HTTP
# endpoints have not been implemented there yet.
NEXT_PUBLIC_NOTIFICATIONS_ENABLED=true

# Socket.io gateway origin (PRO-06). Same host:port as the backend but WITHOUT
# /api — WebSocket gateways are not under the HTTP global prefix. The browser
# connects here directly (a socket can't be proxied through a Route Handler)
# and sends the httpOnly auth cookie via withCredentials. NOT a secret.
# Unset = realtime off; consumers fall back to polling.
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
