# ─────────────────────────── Local port map ───────────────────────────
# Keep these consistent across the whole team.
#   Frontend (Next.js dev):  http://localhost:3000
#   Backend  (NestJS):       http://localhost:3001   REST under /api, socket at root
#   Prisma dev database:     localhost:51213         (fixed by `prisma dev`)
# ───────────────────────────────────────────────────────────────────────

# Backend origin for the BFF proxy (server-side; never called from the browser).
# INCLUDES the /api prefix — the NestJS app sets a global 'api' prefix, so its
# routes live at http://localhost:3001/api/*. The mock backend also accepts a
# leading /api, so this ONE value works whether API_MOCKING is on or off.
NESTJS_API_URL=http://localhost:3001/api

# "disabled" → talk to the real NestJS backend on :3001 (team default).
# "enabled"  → the in-process mock backend serves the API, for solo frontend
#              work with no backend running. Flipping this needs no other change.
API_MOCKING=disabled

# Socket.io gateway origin (PRO-06). Same host:port as the backend but WITHOUT
# /api — WebSocket gateways are not under the HTTP global prefix. The browser
# connects here directly (a socket can't be proxied through a Route Handler)
# and sends the httpOnly auth cookie via withCredentials. NOT a secret.
# Unset = realtime off; consumers fall back to polling.
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
