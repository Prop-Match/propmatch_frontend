# NestJS backend origin. Leave the mock backend running (API_MOCKING=enabled)
# until a real backend is deployed, then point this at it and flip the flag off.
NESTJS_API_URL=http://localhost:3001/api

# When "enabled", app/api/** Route Handlers are served by the MSW mocks in
# src/mocks instead of NESTJS_API_URL. See instrumentation.ts.
API_MOCKING=enabled

# Socket.io gateway origin (PRO-06). Public because a websocket can't be
# proxied through a Route Handler — the browser connects to the backend
# directly. NOT a secret: it carries no token. The browser sends the httpOnly
# auth cookie via withCredentials, so the gateway must accept cookie-based
# handshake auth and allow this app's origin with credentials.
# Unset = realtime off; every consumer falls back to polling.
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
